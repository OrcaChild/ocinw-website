# =============================================================================
# Orca Child in the Wild — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email (Resend) ---
RESEND_API_KEY=re_your-api-key

# --- External APIs ---
# NOAA Tides & Currents (free, no key required)
NEXT_PUBLIC_NOAA_API_URL=https://api.tidesandcurrents.noaa.gov/api/prod/datagetter

# Open-Meteo Weather (free, no key required)
NEXT_PUBLIC_OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast

# --- Zeffy Donation Platform ---
NEXT_PUBLIC_ZEFFY_EMBED_URL=https://www.zeffy.com/en-US/embed/your-form-id

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Orca Child in the Wild
